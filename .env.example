# myassistant — environment variables
# Copy this file to .env and fill in the required values.
# Never commit .env to source control.

# ── LLM Provider (required) ──────────────────────────────────────────────────
# Supported values: openai, anthropic, gemini, openrouter, groq, deepseek, ollama
PROVIDER=openai

# Model name recognised by the chosen provider
ZEROCLAW_MODEL=gpt-4o

# API key for the chosen provider
API_KEY=sk-...

# ── WhatsApp Cloud API (required for webhook / Cloud API mode) ────────────────
# Obtain from https://developers.facebook.com → WhatsApp → Configuration
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# A random string you invent; used during webhook verification
WHATSAPP_VERIFY_TOKEN=
# Optional — adds HMAC signature verification of incoming webhooks
WHATSAPP_APP_SECRET=

# ── Optional overrides ────────────────────────────────────────────────────────
# The port zeroclaw listens on (default: 42617)
# ZEROCLAW_GATEWAY_PORT=42617

# Public HTTPS URL of your server (needed for WhatsApp webhook registration)
# ZEROCLAW_PUBLIC_URL=https://myassistant.example.com
